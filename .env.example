# ─── Backend ───────────────────────────────────────────────────────────────────
BE_PORT=5000

# ─── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost        # Use "postgres" when running via Docker Compose
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=expense_tracker

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=24h
SALT_ROUNDS=10

# ─── AI (Google Gemini) ────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Frontend ──────────────────────────────────────────────────────────────────
# The URL the frontend JS will use to reach the backend
# Change to http://localhost:5000 for local dev without Docker
VITE_API_BASE_URL=http://localhost:5000
